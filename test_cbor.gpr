with "cbor_ada.gpr";
with "config/cbor_ada_config.gpr";

project Test_Cbor is

   for Main use ("test_cbor.adb");
   for Source_Dirs use ("test");
   for Object_Dir use "obj/test";
   for Exec_Dir use "bin";

   package Linker is
      case Cbor_Ada_Config.Alire_Host_OS is
         when "macos" =>
            for Switches ("Ada") use
              ("-L" & external ("SDKROOT",
               "/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk")
               & "/usr/lib");
         when others =>
            null;
      end case;
   end Linker;

   package Compiler is
      for Switches ("Ada") use
        ("-g", "-O0", "-gnatwa", "-gnatW8",
         "-gnatyM120", "-gnat2022",
         "-gnato", "-gnata");
   end Compiler;

end Test_Cbor;
